{
    "name": "martinorton/modern-job-board",
    "description": "A WordPress job board plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MJB\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs -n",
        "phpcbf": "phpcbf",
        "make-pot": "php bin/make-pot.php",
        "make-charts-css": "php bin/make-charts-css.php",
        "seed-demo": "php bin/seed-demo.php \"C:\\Users\\marti\\4Mation Digital\\mjb-local-test\"",
        "sync-local": "powershell -ExecutionPolicy Bypass -File bin/sync-local-test.ps1"
    }
}